# infra/.env.example
# Copy this to infra/.env and fill in values. NEVER commit infra/.env to git.
#
# Usage: `make dev-up` reads infra/.env automatically.
#        For native WSL2 dev, source it: `set -a && source infra/.env && set +a`

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET_KEY=REPLACE_ME_generate_a_random_hex_string

# Auth mode — controls what the login page shows and which paths are active:
#   password  password form only (non-Entra users, e.g. contractors)
#   oidc      "Sign in with Microsoft" button only (PremiumIQ Entra accounts)
#   both      both options shown — recommended for development
AUTH_MODE=both

# Entra ID (Azure AD) OIDC settings. Required for production auth.
ENTRA_TENANT_ID=4dcbd443-2dae-4065-b806-17d9c7781f58
ENTRA_CLIENT_ID=e2e1c2d1-c25e-4daa-9faf-65a07ea94460
ENTRA_CLIENT_SECRET=<>
ENTRA_REDIRECT_URI=http://localhost:8000/auth/callback
ENTRA_ADMIN_OBJECT_ID=1f2f07a2-b148-4187-813c-420f13c7a16c


# ── Redis ─────────────────────────────────────────────────────────────────────
# In docker mode: Redis runs inside linux-box, so use 127.0.0.1 (localhost inside the container).
# In native WSL2 mode: Redis also runs locally, so same URL.
# Redis MUST run with AOF durability (appendonly yes, appendfsync everysec).
# make wsl-start and start-all.sh both start Redis with these flags automatically.
REDIS_URL=redis://127.0.0.1:6379/0

# ── RWB Job queue — heartbeat and reconciler ──────────────────────────────────
# How often the daemon heartbeat thread stamps rwb_job_heartbeat (seconds).
RWB_HEARTBEAT_INTERVAL_SECS=15

# How old a heartbeat must be before the reconciler reclaims the job.
# Keep this at 3-4× INTERVAL — a transient DB blip must not cause false reclaims.
RWB_HEARTBEAT_STALE_SECS=45

# How often the poller runs the reconciler sweep (seconds).
RWB_RECONCILE_INTERVAL_SECS=30

# ── SQL Server SA password (docker sqlserver container) ───────────────────────
# Must meet SQL Server complexity requirements: min 8 chars, upper + lower + digit + symbol.
MSSQL_SA_PASSWORD=Clarity0821!

# ── WORKBENCH database connection ─────────────────────────────────────────────
# In docker mode: sqlserver is the hostname (Docker internal DNS).
# In native WSL2 mode: use localhost (SQL Server container maps port 1433 to host).
MSSQL_WORKBENCH_SERVER=sqlserver
MSSQL_WORKBENCH_PORT=1433
MSSQL_WORKBENCH_DATABASE=rwb_workbench
MSSQL_WORKBENCH_USER=sa
MSSQL_WORKBENCH_PASSWORD=Clarity0821!
MSSQL_WORKBENCH_POOL_SIZE=10
MSSQL_WORKBENCH_POOL_MAX_OVERFLOW=20

# ── EXPOSURE database connection ──────────────────────────────────────────────
MSSQL_EXPOSURE_SERVER=sqlserver
MSSQL_EXPOSURE_PORT=1433
MSSQL_EXPOSURE_DATABASE=rwb_exposure
MSSQL_EXPOSURE_USER=sa
MSSQL_EXPOSURE_PASSWORD=Clarity0821!
MSSQL_EXPOSURE_POOL_SIZE=5
MSSQL_EXPOSURE_POOL_MAX_OVERFLOW=5

# ── LOSS database connection ───────────────────────────────────────────────────
MSSQL_LOSS_SERVER=sqlserver
MSSQL_LOSS_PORT=1433
MSSQL_LOSS_DATABASE=rwb_loss
MSSQL_LOSS_USER=sa
MSSQL_LOSS_PASSWORD=Clarity0821!
MSSQL_LOSS_POOL_SIZE=5
MSSQL_LOSS_POOL_MAX_OVERFLOW=5

# ── DATABRIDGE connection (Moody's — read-only, never migrated) ───────────────
# Fill in with Moody's-provided credentials. Not required for local dev without IRP.
MSSQL_DATABRIDGE_SERVER=
MSSQL_DATABRIDGE_PORT=1433
MSSQL_DATABRIDGE_DATABASE=
MSSQL_DATABRIDGE_USER=
MSSQL_DATABRIDGE_PASSWORD=

# ── Global SQL Server settings ────────────────────────────────────────────────
MSSQL_DRIVER="ODBC Driver 18 for SQL Server"
MSSQL_TRUST_CERT=yes
MSSQL_TIMEOUT=30

# ── IRP / irp-integration ─────────────────────────────────────────────────────
# Required for IRP-connected features. Not required for local dev without IRP.
IRP_API_URL=
IRP_API_KEY=

